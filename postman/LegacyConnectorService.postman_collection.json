              "});",
              "",
              "pm.test('Sincronizacion completada', function () {",
              "  pm.expect(body).to.include('SincronizarDatosRepositorioResponse');",
              "  pm.expect(body).to.include('SUCCESS');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/xml; charset=utf-8"
          },
          {
            "key": "SOAPAction",
            "value": "http://mtis.ua.es/elearning/legacy/SincronizarDatosRepositorio"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:leg=\"http://mtis.ua.es/elearning/legacy\">\n  <soapenv:Header/>\n  <soapenv:Body>\n    <leg:SincronizarDatosRepositorioRequest>\n      <leg:sourceSystem>legacy-lms</leg:sourceSystem>\n      <leg:catalogId>catalog-demo</leg:catalogId>\n      <leg:requestedBy>postman</leg:requestedBy>\n      <leg:requestId>REQ-POSTMAN-001</leg:requestId>\n    </leg:SincronizarDatosRepositorioRequest>\n  </soapenv:Body>\n</soapenv:Envelope>"
        },
        "url": {
          "raw": "{{legacyEndpoint}}",
          "host": [
            "{{legacyEndpoint}}"
          ]
        }
      },
      "response": []
    },
